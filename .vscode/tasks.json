{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet: build",
      "type": "shell",
      "command": "dotnet build App.sln",
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "dotnet run --project App/App.csproj",
      "group": "build",
      "isBackground": true,
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "label": "Backend (.NET)"
      }
    },
    {
      "label": "Run Frontend",
      "type": "shell",
      "command": "npm run start",
      "options": {
        "cwd": "${workspaceFolder}/App/frontend"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "label": "Frontend (Angular)"
      }
    },
    {
      "label": "Run All",
      "dependsOn": ["Run Backend", "Run Frontend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
