{
  "model": "opus",
  "effortLevel": "high",
  "advisorModel": "opus",
  "permissions": {
    "allow": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git switch*)",
      "Bash(git merge*)",
      "Bash(git branch -d*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git tag*)",
      "Bash(gh issue*)",
      "Bash(gh label*)",
      "Bash(gh api repos/*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr view*)",
      "Bash(gh pr ready*)",
      "Bash(gh run watch*)",
      "Bash(gh run view*)",
      "Bash(curl -sf*)",
      "Bash(dotnet format*)",
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(npm run*)",
      "Bash(npx ng lint*)",
      "Bash(docker compose -f docker-compose.dev.yml*)",
      "Bash(dotnet run*)",
      "Bash(npm start*)"
    ]
  },
  "mcpServers": {
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/fast-gate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-push-ci-watch.sh\""
          }
        ]
      }
    ]
  }
}
